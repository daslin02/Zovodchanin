<Page x:Class="Zovodchanin.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MainPage">

    <Page.Resources>
        <!-- Light Theme Colors (Default) -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="TextBrush" Color="#111111"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#65676B"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E4E6EB"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0084FF"/>
        <SolidColorBrush x:Key="MessageBubbleBrush" Color="#E4E6EB"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#E4E6EB"/>
        <SolidColorBrush x:Key="InputBrush" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="TimeBrush" Color="#8A8D91"/>

        <!-- Style for Chat List Buttons -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Padding="15,12" Cursor="Hand">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#D8E3FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Theme Toggle Button -->
        <Style x:Key="ThemeButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left: Chat List -->
            <ColumnDefinition Width="280"/>
            <!-- Center: Main Chat Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Chat List -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <!-- Initially empty, populated via ChatListAddChat -->
            <ListBox x:Name="ChatListBox" 
                     BorderThickness="0" 
                     Background="Transparent" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Button containing only the chat name -->
                        <Button Content="{Binding}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                HorizontalContentAlignment="Left"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextBrush}"
                                Cursor="Hand"
                                Click="ChatButton_Click"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- RIGHT PANEL: Main Chat Area -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <!-- Top bar with theme button -->
                <RowDefinition Height="*"/>
                <!-- Messages area -->
                <RowDefinition Height="70"/>
                <!-- Input area -->
            </Grid.RowDefinitions>

            <!-- Top Right: Theme Toggle Button -->
            <Button Grid.Row="0" x:Name="ThemeButton" Style="{StaticResource ThemeButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" Click="ThemeButton_Click">
                <TextBlock x:Name="ThemeIcon" Text="🌙" FontSize="18"/>
            </Button>

            <!-- Center: Messages Area (Initially empty) -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="20">
                <ItemsControl x:Name="MessagesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Message Card: Contains User Name, Message Text and Time -->
                            <Border Background="{DynamicResource MessageBubbleBrush}" 
                                    CornerRadius="8" 
                                    Padding="12" 
                                    MaxWidth="500" 
                                    HorizontalAlignment="Left" 
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <!-- Header: User Name and Time -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- User Name -->
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding UserName}" 
                                                   FontWeight="Bold" 
                                                   FontSize="13" 
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>

                                        <!-- Time -->
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Time}" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource TimeBrush}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                    </Grid>

                                    <!-- Message Text -->
                                    <TextBlock Text="{Binding Text}" 
                                               FontSize="14" 
                                               Foreground="{DynamicResource TextBrush}" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Bottom: Input Area -->
            <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageInput" 
                             Grid.Column="0"
                             Height="45" 
                             VerticalContentAlignment="Center" 
                             Padding="15,0" 
                             FontSize="14"
                             Background="{DynamicResource InputBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             BorderThickness="0"
                             KeyDown="MessageInput_KeyDown"/>

                    <Button Grid.Column="1" 
                            Width="45" Height="45"
                            Background="{DynamicResource AccentBrush}" 
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="SendButton_Click">
                        <TextBlock Text="➤" FontSize="18" Foreground="White" Margin="0,-2,0,0"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>